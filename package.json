{
  "name": "@anarkisti/eslint-config",
  "version": "1.1.0",
  "description": "Unified ESLint configuration for Node, React, Svelte and plain web projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eetu/eslint-config.git"
  },
  "type": "module",
  "main": "index.js",
  "files": [
    "index.js",
    "index.d.ts",
    "node.js",
    "node.d.ts",
    "react.js",
    "react.d.ts",
    "svelte.js",
    "svelte.d.ts",
    "web.js",
    "web.d.ts",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./node": {
      "types": "./node.d.ts",
      "default": "./node.js"
    },
    "./react": {
      "types": "./react.d.ts",
      "default": "./react.js"
    },
    "./svelte": {
      "types": "./svelte.d.ts",
      "default": "./svelte.js"
    },
    "./web": {
      "types": "./web.d.ts",
      "default": "./web.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint -c node.js node.js && eslint -c node.js react.js svelte.js web.js",
    "prepublishOnly": "yarn test && yarn lint && npm pack --dry-run"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.8.11",
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-svelte": "^3.12.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.60.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "eslint": "^10.4.1",
    "expect-type": "^1.3.0",
    "react": "^19.2.7",
    "svelte": "^5.56.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "eslint": ">= 9",
    "svelte": ">= 5"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.9.1"
}
