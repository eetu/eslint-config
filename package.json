{
  "name": "eslint-config",
  "version": "2.1.0",
  "description": "Unified ESLint configuration for Node, React and Svelte projects",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./node": {
      "types": "./node.d.ts",
      "default": "./node.js"
    },
    "./react": {
      "types": "./react.d.ts",
      "default": "./react.js"
    },
    "./svelte": {
      "types": "./svelte.d.ts",
      "default": "./svelte.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint -c node.js node.js && eslint -c node.js react.js svelte.js"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.8.11",
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-svelte": "^3.12.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.60.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "eslint": "^10.4.1",
    "expect-type": "^1.3.0",
    "react": "^19.2.7",
    "svelte": "^5.56.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "eslint": ">= 9",
    "svelte": ">= 5"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.9.1"
}
